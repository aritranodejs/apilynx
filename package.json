{
  "name": "apilynx",
  "version": "1.0.0",
  "description": "Apilynx — Modern API testing desktop application",
  "author": {
    "name": "Aritra Dutta",
    "email": "aritra@apilynx.app"
  },
  "license": "MIT",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc -p electron/tsconfig.json && tsc-alias -p electron/tsconfig.json -f 'dist-electron/src/**/*.js' && node scripts/fix-electron-imports.js",
    "icons": "python3 scripts/generate-icons.py",
    "electron:dev": "cross-env NODE_ENV=development concurrently -k -n compile,next,electron -c yellow,cyan,magenta \"npm run electron:compile\" \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:dev:fast": "cross-env NODE_ENV=development concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run icons && npm run build && npm run electron:compile",
    "electron:start": "cross-env NODE_ENV=production electron .",
    "dist": "npm run electron:build && electron-builder --config electron-builder.yml",
    "dist:win": "npm run electron:build && electron-builder --win --config electron-builder.yml",
    "dist:mac": "npm run electron:build && electron-builder --mac --config electron-builder.yml",
    "dist:linux": "npm run electron:build && electron-builder --linux --config electron-builder.yml",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-virtual": "^3.13.12",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "mongoose": "^8.9.5",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^3.0.6",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}
